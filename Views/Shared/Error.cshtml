@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<style>
    .error-wrapper {
        max-width: 640px;
        margin: 0 auto;
        text-align: center;
        animation: fadeSlideUp 0.6s ease both;
    }

    .error-icon {
        font-size: 4rem;
        margin-bottom: 1rem;
    }

    .error-header h1 {
        font-size: clamp(1.8rem, 4vw, 2.4rem);
        font-weight: 700;
        background: linear-gradient(135deg, #FF6584, #ff8fab);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin-bottom: 0.5rem;
    }

    .error-header p {
        color: rgba(255,255,255,0.5);
        font-size: 0.95rem;
        margin-bottom: 2rem;
    }

    .error-card {
        background: rgba(255,101,132,0.06);
        border: 1px solid rgba(255,101,132,0.2);
        border-radius: 20px;
        padding: 2rem;
        backdrop-filter: blur(20px);
        box-shadow: 0 8px 40px rgba(0,0,0,0.35);
        text-align: left;
        margin-bottom: 1.5rem;
    }

    .error-card .section-label {
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 1.2px;
        text-transform: uppercase;
        color: rgba(255,101,132,0.7);
        margin-bottom: 0.75rem;
    }

    .request-id-code {
        background: rgba(0,0,0,0.3);
        border: 1px solid rgba(255,101,132,0.2);
        border-radius: 8px;
        padding: 0.5rem 1rem;
        font-family: monospace;
        font-size: 0.85rem;
        color: #ff8fab;
        word-break: break-all;
        display: block;
    }

    .dev-card {
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 20px;
        padding: 2rem;
        text-align: left;
        color: rgba(255,255,255,0.65);
        font-size: 0.88rem;
        line-height: 1.7;
    }

    .dev-card strong { color: rgba(255,255,255,0.85); }

    @@keyframes fadeSlideUp {
        from { opacity: 0; transform: translateY(20px); }
        to   { opacity: 1; transform: translateY(0); }
    }
</style>

<div class="error-wrapper">
    <div class="error-icon">⚠️</div>
    <div class="error-header">
        <h1>Something went wrong.</h1>
        <p>An error occurred while processing your request.</p>
    </div>

    @if (Model.ShowRequestId)
    {
        <div class="error-card">
            <div class="section-label">Request ID</div>
            <code class="request-id-code">@Model.RequestId</code>
        </div>
    }

    <div class="dev-card">
        <div style="font-size:0.75rem;font-weight:600;letter-spacing:1.2px;text-transform:uppercase;color:rgba(255,255,255,0.35);margin-bottom:0.75rem;">Development Mode</div>
        <p>
            Swapping to <strong>Development</strong> environment will display more detailed information about the error that occurred.
        </p>
        <p>
            <strong>The Development environment shouldn't be enabled for deployed applications.</strong>
            It can result in displaying sensitive information from exceptions to end users.
            For local debugging, enable the <strong>Development</strong> environment by setting the <strong>ASPNETCORE_ENVIRONMENT</strong> environment variable to <strong>Development</strong>
            and restarting the app.
        </p>
    </div>
</div>
