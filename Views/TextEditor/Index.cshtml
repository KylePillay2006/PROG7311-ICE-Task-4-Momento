@{
    ViewData["Title"] = "Text Editor";
}

<style>
    .editor-wrapper {
        max-width: 800px;
        margin: 0 auto;
    }

    /* Page Header */
    .page-header {
        text-align: center;
        margin-bottom: 2.5rem;
        animation: fadeSlideUp 0.5s ease both;
    }

    .page-header .badge-label {
        display: inline-block;
        background: linear-gradient(135deg, rgba(108, 99, 255, 0.3), rgba(0, 201, 167, 0.3));
        border: 1px solid rgba(108, 99, 255, 0.4);
        color: #a29bfe;
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        padding: 0.3rem 0.9rem;
        border-radius: 50px;
        margin-bottom: 1rem;
    }

    .page-header h1 {
        font-size: clamp(1.8rem, 4vw, 2.6rem);
        font-weight: 700;
        margin-bottom: 0.5rem;
        background: linear-gradient(135deg, #ffffff, #a29bfe, #00C9A7);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        line-height: 1.2;
    }

    .page-header p {
        color: rgba(255, 255, 255, 0.5);
        font-size: 0.95rem;
        margin: 0;
    }

    /* Glass Card */
    .glass-card {
        background: rgba(255, 255, 255, 0.06);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 20px;
        padding: 2rem;
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        box-shadow: 0 8px 40px rgba(0, 0, 0, 0.35), inset 0 1px 0 rgba(255, 255, 255, 0.08);
        margin-bottom: 1.5rem;
        animation: fadeSlideUp 0.6s ease both;
    }

    .glass-card:nth-child(2) {
        animation-delay: 0.1s;
    }

    .glass-card:nth-child(3) {
        animation-delay: 0.2s;
    }

    .card-section-title {
        font-size: 0.8rem;
        font-weight: 600;
        letter-spacing: 1.2px;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.4);
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .card-section-title::after {
        content: '';
        flex: 1;
        height: 1px;
        background: rgba(255, 255, 255, 0.08);
    }

    /* Textarea */
    .editor-textarea {
        width: 100%;
        min-height: 220px;
        background: rgba(0, 0, 0, 0.25);
        border: 1.5px solid rgba(255, 255, 255, 0.1);
        border-radius: 12px;
        color: #f0f0f0;
        font-family: 'Inter', monospace;
        font-size: 0.95rem;
        line-height: 1.7;
        padding: 1rem 1.25rem;
        resize: vertical;
        transition: all 0.3s ease;
        outline: none;
    }

    .editor-textarea::placeholder {
        color: rgba(255, 255, 255, 0.25);
    }

    .editor-textarea:focus {
        border-color: rgba(108, 99, 255, 0.7);
        background: rgba(0, 0, 0, 0.35);
        box-shadow: 0 0 0 3px rgba(108, 99, 255, 0.15), 0 4px 20px rgba(0, 0, 0, 0.3);
    }

    /* Buttons */
    .btn-actions {
        display: flex;
        gap: 0.75rem;
        margin-top: 1.25rem;
        flex-wrap: wrap;
    }

    .btn-save {
        background: linear-gradient(135deg, #6C63FF, #574fd6);
        color: #fff;
        border: none;
        border-radius: 10px;
        padding: 0.65rem 1.6rem;
        font-size: 0.9rem;
        font-weight: 600;
        font-family: 'Inter', sans-serif;
        cursor: pointer;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(108, 99, 255, 0.4);
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
    }

    .btn-save:hover {
        transform: translateY(-2px) scale(1.03);
        box-shadow: 0 8px 25px rgba(108, 99, 255, 0.55);
        background: linear-gradient(135deg, #7b73ff, #6C63FF);
    }

    .btn-save:active {
        transform: translateY(0) scale(0.98);
    }

    .btn-undo {
        background: rgba(255, 255, 255, 0.08);
        color: rgba(255, 255, 255, 0.85);
        border: 1.5px solid rgba(255, 255, 255, 0.15);
        border-radius: 10px;
        padding: 0.65rem 1.6rem;
        font-size: 0.9rem;
        font-weight: 600;
        font-family: 'Inter', sans-serif;
        cursor: pointer;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        backdrop-filter: blur(8px);
    }

    .btn-undo:hover {
        background: rgba(255, 101, 132, 0.15);
        border-color: rgba(255, 101, 132, 0.5);
        color: #FF6584;
        transform: translateY(-2px) scale(1.03);
        box-shadow: 0 8px 20px rgba(255, 101, 132, 0.2);
    }

    .btn-undo:active {
        transform: translateY(0) scale(0.98);
    }

    /* Divider */
    .section-divider {
        height: 1px;
        background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.1), transparent);
        margin: 2rem 0;
    }

    /* Version History */
    .history-empty {
        text-align: center;
        padding: 2rem;
        color: rgba(255, 255, 255, 0.3);
        font-size: 0.9rem;
        border: 1.5px dashed rgba(255, 255, 255, 0.1);
        border-radius: 12px;
    }

    .history-empty .icon {
        font-size: 2rem;
        margin-bottom: 0.5rem;
        display: block;
    }

    .version-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .version-item {
        background: rgba(0, 0, 0, 0.2);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 12px;
        padding: 0.9rem 1.1rem;
        font-size: 0.88rem;
        color: rgba(255, 255, 255, 0.75);
        line-height: 1.5;
        transition: all 0.3s ease;
        display: flex;
        align-items: flex-start;
        gap: 0.75rem;
        animation: fadeSlideUp 0.4s ease both;
    }

    .version-item:hover {
        border-color: rgba(108, 99, 255, 0.35);
        background: rgba(108, 99, 255, 0.08);
        color: rgba(255, 255, 255, 0.95);
        transform: translateX(4px);
    }

    .version-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: linear-gradient(135deg, #6C63FF, #00C9A7);
        margin-top: 5px;
        flex-shrink: 0;
        box-shadow: 0 0 6px rgba(108, 99, 255, 0.5);
    }

    .version-text {
        flex: 1;
        word-break: break-word;
        font-family: 'Inter', monospace;
    }

    @@keyframes fadeSlideUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@media (max-width: 576px) {
        .glass-card {
            padding: 1.25rem;
        }

        .btn-actions {
            flex-direction: column;
        }

        .btn-save,
        .btn-undo {
            width: 100%;
            justify-content: center;
        }
    }

    .btn-redo {
        background: rgba(255, 255, 255, 0.08);
        color: rgba(255, 255, 255, 0.85);
        border: 1.5px solid rgba(255, 255, 255, 0.15);
        border-radius: 10px;
        padding: 0.65rem 1.6rem;
        font-size: 0.9rem;
        font-weight: 600;
        font-family: 'Inter', sans-serif;
        cursor: pointer;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        backdrop-filter: blur(8px);
    }

    .btn-redo:hover {
        background: rgba(0, 201, 167, 0.15);
        border-color: rgba(0, 201, 167, 0.5);
        color: #00C9A7;
        transform: translateY(-2px) scale(1.03);
        box-shadow: 0 8px 20px rgba(0, 201, 167, 0.2);
    }

    .btn-redo:disabled,
    .btn-undo:disabled {
        opacity: 0.35;
        cursor: not-allowed;
        transform: none !important;
        box-shadow: none !important;
    }
</style>

<div class="editor-wrapper">

    <!-- Page Header -->
    <div class="page-header">
        <div class="badge-label">Memento Pattern</div>
        <h1>Smart Text Editor</h1>
        <p>Write, save versions, and undo changes with ease.</p>
    </div>

    <!-- Editor Card -->
    <div class="glass-card">
        <div class="card-section-title">✦ Editor</div>
        <form asp-controller="TextEditor" asp-action="Save" method="post">
            <textarea class="editor-textarea" name="content"
                      placeholder="Start typing your content here...">@ViewBag.Content</textarea>
            <div class="btn-actions">
                <button type="submit" class="btn-save">
                    <span>💾</span> Save Version
                </button>
            </div>
        </form>
    </div>

    <!-- Undo / Redo Card -->
    <div class="glass-card" style="animation-delay:0.1s">
        <div class="card-section-title">↩ Actions</div>
        <div class="btn-actions">
            <form asp-controller="TextEditor" asp-action="Undo" method="post">
                <button type="submit" class="btn-undo" @(ViewBag.CanUndo ? "" : "disabled")>
                    <span>↩</span> Undo
                </button>
            </form>
            <form asp-controller="TextEditor" asp-action="Redo" method="post">
                <button type="submit" class="btn-redo" @(ViewBag.CanRedo ? "" : "disabled")>
                    <span>↪</span> Redo
                </button>
            </form>
        </div>
    </div>

    <div class="section-divider"></div>

    <!-- Version History Card -->
    <div class="glass-card" style="animation-delay:0.2s">
        <div class="card-section-title">🕓 Version History</div>

        @if (ViewBag.History != null && ViewBag.History.Count > 0)
        {
            <ul class="version-list">
                @foreach (var version in ViewBag.History)
                {
                    <li class="version-item">
                        <span class="version-dot"></span>
                        <span class="version-text">@version.Content</span>
                    </li>
                }
            </ul>
        }
        else
        {
            <div class="history-empty">
                <span class="icon">📂</span>
                No saved versions yet. Save your first version above!
            </div>
        }
    </div>

</div>