@{
    ViewData["Title"] = "Privacy Policy";
}

<style>
    .privacy-wrapper {
        max-width: 720px;
        margin: 0 auto;
        animation: fadeSlideUp 0.6s ease both;
    }

    .privacy-header {
        text-align: center;
        margin-bottom: 2.5rem;
    }

    .privacy-header .badge-label {
        display: inline-block;
        background: linear-gradient(135deg, rgba(0,201,167,0.2), rgba(108,99,255,0.2));
        border: 1px solid rgba(0,201,167,0.35);
        color: #00C9A7;
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        padding: 0.3rem 0.9rem;
        border-radius: 50px;
        margin-bottom: 1rem;
    }

    .privacy-header h1 {
        font-size: clamp(1.8rem, 4vw, 2.4rem);
        font-weight: 700;
        background: linear-gradient(135deg, #ffffff, #00C9A7);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin-bottom: 0.5rem;
    }

    .privacy-header p {
        color: rgba(255,255,255,0.45);
        font-size: 0.95rem;
    }

    .privacy-card {
        background: rgba(255,255,255,0.06);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 20px;
        padding: 2.5rem;
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        box-shadow: 0 8px 40px rgba(0,0,0,0.35), inset 0 1px 0 rgba(255,255,255,0.08);
        color: rgba(255,255,255,0.75);
        line-height: 1.8;
        font-size: 0.95rem;
    }

    .privacy-card p {
        margin-bottom: 1rem;
    }

    @@keyframes fadeSlideUp {
        from { opacity: 0; transform: translateY(20px); }
        to   { opacity: 1; transform: translateY(0); }
    }
</style>

<div class="privacy-wrapper">
    <div class="privacy-header">
        <div class="badge-label">Legal</div>
        <h1>@ViewData["Title"]</h1>
        <p>Transparency about how we handle your data.</p>
    </div>
    <div class="privacy-card">
        <p>Use this page to detail your site's privacy policy.</p>
    </div>
</div>
